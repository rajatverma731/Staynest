<% layout('layouts/boilerPlate') %>
     <h3>
         <br>
            Edit this list
    </h3>
 <br>
    <form action="/listings/<%= listing._id %>?_method=PUT" method="POST"> 
<div class="row">
    <div class="col-8 offset-2">
        <div>
            <label for="title" class="form-label">Change Title</label>
        <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control">
        </div>

        <br>

        <div>
            <label for="descriptiion" class="form-label">Description</label>
            <textarea type="text" name="listing[description]"<%= listing.description %> class= "form-control"> </textarea>
        </div>
        
        <br>

        <div>
            <label for="image" class="form-label">Add Image Llink</label>
            <input type="text" name="listing[image]" value="<%= listing.title %>" class="form-control">
        </div>
        
        <br>

        <div class="row">
             <div class="mb-3 col-md-4">
            <label for="price" class="form-label"> Add Price</label>
            <input type="number" name="listing[price]"value="<%= listing.price %>" class="form-control">

        </div>
        <div class="mb-3 col-md-4">
            <label for="country" class="form-label">Country</label>
        <input type="text" name="listing[country]" value="<%= listing.price %>" class="form-control">
        </div>
        </div>
       

        <br>

        <div>
            <label for="location" class="form-label"> Location</label>
            <input type="text" name="listing[location]" value="<%= listing.location %>" class="form-control">

        </div>
        </div>
        </div>
        <br>
        <button class="button-add">Add</button>
    </form>
</body>
